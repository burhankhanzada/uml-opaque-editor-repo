<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <!-- Command definition -->
   <extension point="org.eclipse.ui.commands">
      <command
            id="com.burhankhanzada.opaquebehavioureditor.command.openBodyEditor"
            name="Open OpaqueBehavior Body Editor">
      </command>
   </extension>

   <!-- Handler -->
   <extension point="org.eclipse.ui.handlers">
      <handler
            commandId="com.burhankhanzada.opaquebehavioureditor.command.openBodyEditor"
            class="com.burhankhanzada.opaquebehavioureditor.OpenBodyEditorHandler"/>
   </extension>

   <!-- Menu Contribution to show the command in a context menu -->
   <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="popup:org.eclipse.ui.popup.any?after=additions">
         <command
               commandId="com.burhankhanzada.opaquebehavioureditor.command.openBodyEditor"
               label="Open Body Editor">
            <!-- Show this menu item ONLY when the user right-clicks an OpaqueBehavior -->
            <visibleWhen checkEnabled="false">
               <with variable="selection">
                  <iterate ifEmpty="false">
                     <!-- This references the UML package namespace to ensure it's a UML element -->
                     <adapt type="org.eclipse.uml2.uml.OpaqueBehavior"/>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>

   <!-- Custom Marker for UML Validation Errors -->
   <extension point="org.eclipse.core.resources.markers"
              id="com.burhankhanzada.opaquebehavioureditor.problem"
              name="UML OpaqueBehavior Error">
      <super type="org.eclipse.core.resources.problemmarker"/>
      <super type="org.eclipse.core.resources.textmarker"/>
      <persistent value="true"/>
   </extension>

   <!-- Editor definition -->
   <extension point="org.eclipse.ui.editors">
      <editor
            id="com.burhankhanzada.opaquebehavioureditor.editor.OpaqueBehaviorEditor"
            name="OpaqueBehavior Body Editor"
            class="com.burhankhanzada.opaquebehavioureditor.ui.OpaqueBehaviorEditor"
            default="false">
      </editor>
   </extension>

</plugin>